{
  "manifest_version": 3,
  "name": "BookmarkAI Url Sync",
  "version": "1.3.1",
  "description": "Saves an extension code and sends supported page data to your API.",
  "permissions": [
    "storage",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "https://localhost:7224/*",
    "https://bookmarkai.site/*",	
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://m.youtube.com/*",
    "https://www.facebook.com/*",
    "https://facebook.com/*",
    "https://m.facebook.com/*",
    "https://web.facebook.com/*",
    "https://www.reddit.com/*",
    "https://reddit.com/*",
    "https://old.reddit.com/*",
    "https://new.reddit.com/*",
    "https://www.tiktok.com/*",
    "https://tiktok.com/*",
    "https://m.tiktok.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://m.youtube.com/*",
        "https://www.facebook.com/*",
        "https://facebook.com/*",
        "https://m.facebook.com/*",
        "https://web.facebook.com/*",
        "https://www.reddit.com/*",
        "https://reddit.com/*",
        "https://old.reddit.com/*",
        "https://new.reddit.com/*",
        "https://www.tiktok.com/*",
        "https://tiktok.com/*",
        "https://m.tiktok.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "BookmarkAI Url Sync",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
